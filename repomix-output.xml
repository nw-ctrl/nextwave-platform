<file path="apps/website/app/globals.css">
:root {
  --bg: #07131f;
  --bg-soft: #0d1f30;
  --surface: rgba(12, 31, 47, 0.72);
  --surface-strong: #132b41;
  --line: rgba(255, 255, 255, 0.14);
  --text: #edf5ff;
  --muted: #abc2d9;
  --brand: #5dd4b1;
  --brand-deep: #179a7f;
  --signal: #f1b459;
}

* {
  box-sizing: border-box;
}

html,
body {
  margin: 0;
  padding: 0;
}

body {
  font-family: var(--font-body), "Segoe UI", sans-serif;
  background:
    radial-gradient(circle at 10% 0%, #15324d 0%, rgba(21, 50, 77, 0) 40%),
    radial-gradient(circle at 85% 20%, rgba(93, 212, 177, 0.28) 0%, rgba(93, 212, 177, 0) 35%),
    linear-gradient(160deg, var(--bg) 0%, #050f19 65%, #030912 100%);
  color: var(--text);
  min-height: 100vh;
}

a {
  color: inherit;
  text-decoration: none;
}

button {
  font: inherit;
}

.page {
  width: min(1180px, 92vw);
  margin: 0 auto;
  padding: 28px 0 80px;
}

.nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16px;
  padding: 12px 16px;
  border: 1px solid var(--line);
  border-radius: 999px;
  background: rgba(9, 22, 34, 0.8);
  backdrop-filter: blur(10px);
  position: sticky;
  top: 16px;
  z-index: 10;
}

.logo {
  display: flex;
  align-items: center;
  gap: 10px;
  font-family: var(--font-display), "Segoe UI", sans-serif;
  letter-spacing: 0.04em;
}

.logo-mark {
  width: 30px;
  height: 30px;
  border-radius: 8px;
  background: linear-gradient(140deg, var(--brand), #8ae2c8 60%, #d6fff4 100%);
  color: #08201a;
  font-weight: 700;
  display: grid;
  place-items: center;
}

.nav-links {
  display: flex;
  gap: 18px;
  color: var(--muted);
  font-size: 0.9rem;
}

.hero {
  margin-top: 42px;
  padding: 44px;
  border-radius: 24px;
  border: 1px solid var(--line);
  background: linear-gradient(155deg, rgba(13, 31, 48, 0.92), rgba(7, 19, 31, 0.9));
  box-shadow: 0 24px 70px rgba(2, 8, 18, 0.42);
}

.tag {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  border-radius: 999px;
  border: 1px solid rgba(93, 212, 177, 0.45);
  background: rgba(93, 212, 177, 0.12);
  color: #c9fff0;
  padding: 8px 14px;
  font-size: 0.78rem;
}

.hero h1 {
  font-family: var(--font-display), "Segoe UI", sans-serif;
  font-size: clamp(2rem, 5.8vw, 4rem);
  line-height: 1.04;
  margin: 18px 0 12px;
}

.hero p {
  color: var(--muted);
  font-size: clamp(1rem, 2.2vw, 1.25rem);
  max-width: 70ch;
}

.hero-actions {
  margin-top: 26px;
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  align-items: flex-start;
}

.btn {
  border-radius: 999px;
  padding: 11px 18px;
  font-weight: 600;
  border: 1px solid transparent;
  cursor: pointer;
}

.btn:disabled {
  cursor: progress;
  opacity: 0.72;
}

.btn-primary {
  background: linear-gradient(140deg, var(--brand), #8ae2c8);
  color: #062319;
}

.btn-secondary {
  border-color: var(--line);
  color: var(--text);
  background: rgba(255, 255, 255, 0.04);
}

.checkout-cta {
  display: grid;
  gap: 8px;
}

.checkout-message {
  margin: 0;
  max-width: 36ch;
  color: #c9fff0;
  font-size: 0.88rem;
}

.section {
  margin-top: 24px;
  border: 1px solid var(--line);
  border-radius: 20px;
  background: var(--surface);
  padding: 28px;
}

.section h2 {
  font-family: var(--font-display), "Segoe UI", sans-serif;
  margin: 0 0 10px;
  font-size: clamp(1.4rem, 2.8vw, 2rem);
}

.section-intro {
  margin: 0;
  color: var(--muted);
}

.grid {
  margin-top: 18px;
  display: grid;
  gap: 14px;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
}

.card {
  border: 1px solid var(--line);
  border-radius: 14px;
  background: rgba(255, 255, 255, 0.03);
  padding: 16px;
}

.card h3 {
  margin: 0 0 8px;
  font-size: 1rem;
}

.card p,
.card li {
  margin: 0;
  color: var(--muted);
  line-height: 1.5;
  font-size: 0.95rem;
}

.card ul {
  margin: 0;
  padding-left: 18px;
}

.status-strip {
  margin-top: 16px;
  display: grid;
  gap: 10px;
  grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
}

.metric {
  border: 1px solid rgba(241, 180, 89, 0.35);
  border-radius: 12px;
  background: rgba(241, 180, 89, 0.1);
  padding: 12px;
}

.metric strong {
  display: block;
  color: #ffe0b0;
  font-size: 1.25rem;
}

.metric span {
  color: #e6c691;
  font-size: 0.82rem;
}

.footer {
  margin-top: 24px;
  color: var(--muted);
  font-size: 0.88rem;
  text-align: center;
}

@media (max-width: 760px) {
  .page {
    padding-top: 14px;
  }

  .nav-links {
    display: none;
  }

  .hero,
  .section {
    padding: 20px;
  }
}
</file>

