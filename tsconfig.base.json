{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@nextwave/ui": ["packages/ui/src"],
      "@nextwave/auth": ["packages/auth/src"],
      "@nextwave/database": ["packages/database/src"],
      "@nextwave/config": ["packages/config/src"],
      "@nextwave/analytics": ["packages/analytics/src"]
    }
  }
}